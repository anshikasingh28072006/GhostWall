{
  "name": "ghostwall",
  "version": "1.0.0",
  "description": "GhostWall AI-Based Cyber Threat Detection Framework",
  "main": "server/index.ts",
  "scripts": {
    "dev": "concurrently -n \"server,client\" -c \"magenta,cyan\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon --watch server -e ts,js --exec ts-node server/index.ts",
    "dev:client": "vite --port 3000",
    "build": "tsc && vite build",
    "start": "ts-node server/index.ts"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
